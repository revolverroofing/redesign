# UPS API credentials — https://developer.ups.com
# Use https://wwwcie.ups.com for the customer integration environment (sandbox)
# and https://onlinetools.ups.com (default) for production.
UPS_CLIENT_ID=
UPS_CLIENT_SECRET=
UPS_ACCOUNT_NUMBER=
UPS_BASE_URL=

# FedEx API credentials — https://developer.fedex.com
# Use https://apis-sandbox.fedex.com for sandbox and https://apis.fedex.com
# (default) for production.
FEDEX_API_KEY=
FEDEX_API_SECRET=
FEDEX_ACCOUNT_NUMBER=
FEDEX_BASE_URL=

# Only needed by the MCP server. Points the MCP server at the Next.js API
# routes — typically http://localhost:3000 in dev, or your deployed URL.
SHIPPING_API_BASE_URL=http://localhost:3000
